# ─── Database ───
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=wallet_service
PG_USER=postgres
PG_PASSWORD=change-me
PG_POOL_MAX=20
# یا:
# DATABASE_URL=postgres://user:pass@localhost:5432/wallet_service

# ─── Redis (برای BullMQ و cache) ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Encryption (با key rotation) ───
# تولید کلید جدید:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# نسخه versioned (توصیه‌شده برای production):
#   WALLET_MASTER_KEY_V1=...
#   WALLET_MASTER_KEY_V2=...   # فعالش کن وقتی می‌خوای rotate کنی
# encrypt همیشه با بالاترین V انجام می‌شه. ردیف‌های قدیمی به‌صورت lazy
# (هر بار که decrypt می‌شن) به جدیدترین V مهاجرت می‌کنن.
#
# legacy (به‌عنوان V1 لود می‌شه — فقط برای backwards compat):
WALLET_MASTER_KEY=

# ─── Auth ───
# هر دو حداقل ۳۲ کاراکتر (base64 از ۳۲ بایت رندوم توصیه میشه)
JWT_SECRET=
COOKIE_SECRET=

# ─── Server ───
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ─── Workers ───
# اگه ست نکنی، GEN_CONCURRENCY = max(1, cpu_cores - 1) خودکار ست می‌شه.
# GEN_CONCURRENCY=
#
# تعداد thread pool برای derivation سنگین (PBKDF2). پیش‌فرض = max(1, cores-1)
# تا حداکثر ۸. مقدار 0 = غیرفعال (همه چیز توی thread اصلی).
# WALLET_DERIVATION_POOL_SIZE=

# Balance worker
BALANCE_CONCURRENCY=5
BALANCE_BATCH_SIZE=200
BALANCE_CHECK_INTERVAL_SEC=30

# ─── Balance API endpoints (default‌ها خوبن، rarely need to change) ───
# BTC provider:
#   esplora         (پیش‌فرض) — mempool.space یا Electrs محلی، per-address، شامل mempool
#   blockchain_info — blockchain.info/multiaddr، تا ۱۰۰ آدرس در هر HTTP، confirmed-only
# BTC_BALANCE_PROVIDER=esplora
# BTC_ESPLORA_URL=https://mempool.space/api
# BTC_BLOCKCHAIN_INFO_URL=https://blockchain.info
# BTC_BALANCE_CONCURRENCY=10
# BTC_INTERCHUNK_DELAY_MS=100
# BTC_BATCH_SIZE=100

# legacy نام (هنوز پشتیبانی می‌شه): BTC_API → BTC_ESPLORA_URL
# BTC_API=https://mempool.space/api
# ETH_RPC=https://eth.llamarpc.com
# TRON_API=https://api.tronstack.io

# ─── Auto-batch / Templates (Phase 2) ───
# Circuit breaker: اگه ست بشه (true|false) DB رو override می‌کنه. خالی → از DB
# (system_settings.auto_batch_enabled، پیش‌فرض true). برای کشتن fast از طریق
# env: AUTO_BATCH_ENABLED=false. برای toggle بدون restart از پنل استفاده کن.
# AUTO_BATCH_ENABLED=

# ─── Seeding credentials (فقط یه بار استفاده می‌شه، بعد پاک کن) ───
# INITIAL_ETH_RPCS=https://rpc1.example,https://rpc2.example
# INITIAL_BTC_APIS=https://btc.example

# ─── GetBlock.io (JSON-RPC provider چندزنجیره‌ای) ───
# توکن‌ها با فرمت shared configuration file وارد می‌شن:
#   {
#     "shared": {
#       "btc": { "mainnet": { "jsonRpc": ["<token>"] } },
#       "eth": { "mainnet": { "jsonRpc": ["<token>"] } }
#     }
#   }
# مرجع: https://docs.getblock.io/getting-started/authentication-with-access-tokens
#
# Region endpoint: io (پیش‌فرض EU/Frankfurt) | us | asia
# GETBLOCK_REGION=io
#
# یکی از دو روش:
#   1) مسیر فایل JSON:
# GETBLOCK_CONFIG_PATH=/path/to/getblock-config.json
#   2) JSON به‌صورت inline:
# GETBLOCK_CONFIG_JSON={"shared":{"eth":{"mainnet":{"jsonRpc":["<token>"]}}}}
#
# برای import یک‌باره به credentials DB:
#   npm run import:getblock  (یا npx tsx scripts/import-getblock.ts <path>)
#   — BTC entries فعلاً skip می‌شن (تا وقتی broadcast flow اضافه بشه).
#   — import شده با benchmark_allowed=false (تا benchmark سهمیهٔ free-tier رو نخوره).
# ادمین می‌تونه همین کار رو از پنل هم انجام بده (صفحهٔ 🔐 API Keys).
