{
  "name": "wallet-service",
  "version": "1.1.0",
  "description": "Multi-chain HD wallet service with admin panel, balance checker, and batch generation",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "start": "tsx src/api/server.ts",
    "worker": "tsx src/worker.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "seed:credentials": "tsx scripts/seed-credentials.ts",
    "import:getblock": "tsx scripts/import-getblock.ts",
    "migrate": "for f in src/db/schema.sql src/db/migrations/*.sql; do psql $DATABASE_URL -f $f; done",
    "test": "node --import tsx --test 'src/**/*.test.ts'",
    "build": "tsc",
    "lint": "eslint 'src/**/*.ts' 'scripts/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.1",
    "bcrypt": "^5.1.1",
    "bip32": "^4.0.0",
    "bip39": "^3.1.0",
    "bitcoinjs-lib": "^6.1.5",
    "bs58check": "^3.0.1",
    "bullmq": "^5.8.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0",
    "fastify": "^4.26.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.5",
    "pino-pretty": "^11.0.0",
    "tiny-secp256k1": "^2.2.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.0",
    "@types/pg": "^8.11.4",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
